# Polymarket News Bot — environment variables (copy to .env and adjust)

# Polymarket
POLYMARKET_API_KEY=
POLYMARKET_SECRET=
POLYMARKET_WALLET_PRIVATE_KEY=
POLYMARKET_CHAIN_ID=137

# News sources
NEWSAPI_KEY=

# LLM (fase 6) — zet een key om hybrid/llm mode te activeren
OPENAI_API_KEY=

# Bot settings
CONFIG_PATH=configs/default.yaml
LOG_FILE=logs/newsbot.log
DRY_RUN=true
